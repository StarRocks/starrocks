-- name: test_broker_load_debezium
create database db_${uuid0};
use db_${uuid0};

shell: ossutil64 mkdir oss://${oss_bucket}/test_broker_load/debezium/${uuid0} >/dev/null || echo "exit 0" >/dev/null
shell: ossutil64 cp --force ./sql/test_broker_load/data/debezium_payload.json oss://${oss_bucket}/test_broker_load/debezium/${uuid0}/ | grep -Pv "(average|elapsed)"
shell: ossutil64 cp --force ./sql/test_broker_load/data/debezium_no_payload.json oss://${oss_bucket}/test_broker_load/debezium/${uuid0}/ | grep -Pv "(average|elapsed)"


-- test_debezium_payload
CREATE TABLE t1 (
    id INT NOT NULL,
    name VARCHAR(100),
    age INT
) PRIMARY KEY (id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1");

LOAD LABEL label0_${uuid1} (
    DATA INFILE("s3://${oss_bucket}/test_broker_load/debezium/${uuid0}/debezium_payload.json")
    INTO TABLE t1
    FORMAT AS "json"
) WITH BROKER (
    "aws.s3.access_key" = "${oss_ak}",
    "aws.s3.secret_key" = "${oss_sk}",
    "aws.s3.endpoint" = "${oss_endpoint}"
)
PROPERTIES
(
    "timeout" = "3600",
    "envelope" = "debezium"
);

function: wait_load_finish("label0_${uuid1}")

select * from t1 order by id;

drop table t1;


