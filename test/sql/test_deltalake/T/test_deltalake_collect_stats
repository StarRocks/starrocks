-- name: testDeltaLakeCollectStats

create external catalog delta_test_${uuid0} PROPERTIES (
    "type"="deltalake",
    "hive.metastore.uris"="${deltalake_catalog_hive_metastore_uris}",
    "aws.s3.access_key"="${oss_ak}",
    "aws.s3.secret_key"="${oss_sk}",
