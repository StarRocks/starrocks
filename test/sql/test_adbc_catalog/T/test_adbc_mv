-- name: test_adbc_mv_lifecycle
set catalog default_catalog;
create external catalog adbc_catalog_${uuid0}
properties
(
    "type"="adbc",
    "adbc.driver"="flight_sql",
    "adbc.url"="grpc://${external_flightsql_ip}:${external_flightsql_port}"
);
create database db_mv_${uuid0};
use db_mv_${uuid0};
create materialized view mv_${uuid0}
distributed by hash(id)
refresh manual
as select id, name from adbc_catalog_${uuid0}.test_db.test_types;
refresh materialized view mv_${uuid0} with sync mode;
select * from mv_${uuid0} order by id;
drop materialized view mv_${uuid0};
drop database db_mv_${uuid0};
drop catalog adbc_catalog_${uuid0};

