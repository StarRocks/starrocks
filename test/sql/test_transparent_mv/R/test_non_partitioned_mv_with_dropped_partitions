CREATE MATERIALIZED VIEW non_partitioned_mv 
REFRESH DEFERRED MANUAL 
PROPERTIES (
    "replication_num" = "1"
)
AS 
SELECT dt, sum(num) as total_num 
FROM mv_iceberg_${uuid0}.mv_iceberg_db_${uuid0}.t1 
GROUP BY dt;
