function: wait_plan_contains('SELECT p, s, x, sum(x) OVER (PARTITION BY p, s ORDER BY x) FROM window_merge_sort_t1', 'MERGING-EXCHANGE', 'ANALYTIC')
SELECT p, s, x, running_sum
FROM (
