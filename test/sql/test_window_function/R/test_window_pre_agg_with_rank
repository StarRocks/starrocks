        SELECT c1, c2, c3, c4, c5
                , c6, row_number() OVER (PARTITION BY t3.c2 ORDER BY c1,c6 ) AS _rowid
                , sum(t3.c2) OVER (PARTITION BY t3.c2) AS _sum
        FROM (
                SELECT *
                FROM t1
                        JOIN t2 ON c2 = c5
        ) t3
) t4
WHERE _rowid  <= 2 order by c4,c6;
