function: assert_explain_costs_contains("SELECT site_id, caller, order_no, network_code, org_name, aa, bb, cc, dd FROM (SELECT *, CASE WHEN aa >= 2 THEN 'Y' ELSE 'N' END AS cc, aa - 1 AS dd FROM (SELECT t.site_id, t.caller, t.order_no, t.network_code, o.org_name, t.start_time, COUNT(1) OVER (PARTITION BY t.caller, t.order_no, t.network_code) AS aa, ROW_NUMBER() OVER (PARTITION BY t.caller, t.order_no, t.network_code ORDER BY t.start_time) AS bb FROM t_rank_count_call t LEFT JOIN t_rank_count_org o ON t.org_code = o.org_code) pro_1) x WHERE caller = '13181698468' AND cc = 'Y' AND bb = 1 ORDER BY order_no, network_code", "PARTITION-TOP-N", "pre agg functions", "count[(1)")
SELECT site_id, caller, order_no, network_code, org_name, aa, bb, cc, dd
FROM (
    SELECT *, CASE WHEN aa >= 2 THEN 'Y' ELSE 'N' END AS cc, aa - 1 AS dd
    FROM (
        SELECT t.site_id, t.caller, t.order_no, t.network_code, o.org_name, t.start_time,
               COUNT(1) OVER (PARTITION BY t.caller, t.order_no, t.network_code) AS aa,
               ROW_NUMBER() OVER (PARTITION BY t.caller, t.order_no, t.network_code ORDER BY t.start_time) AS bb
        FROM t_rank_count_call t
        LEFT JOIN t_rank_count_org o ON t.org_code = o.org_code
    ) pro_1
) x
WHERE caller = '13181698468' AND cc = 'Y' AND bb = 1
ORDER BY order_no, network_code;
