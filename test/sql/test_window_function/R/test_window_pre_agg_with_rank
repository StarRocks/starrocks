FROM (
        SELECT c1, c2, c3, c4, c5,c6, row_number() OVER (PARTITION BY c2 ORDER BY c1,c6 ) AS _rowid
                , sum(c2) OVER (PARTITION BY t3.c2) AS _sum, 
                	avg(c2) OVER (PARTITION BY t3.c2) AS _avg
        FROM (
                SELECT *
                FROM t1
