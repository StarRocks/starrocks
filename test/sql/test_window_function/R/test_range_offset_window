-- name: test_range_offset_window
CREATE TABLE `test_range_offset_window` (
    `id` int NOT NULL,
    `k` int NULL,
    `dec_k` decimal(10, 2) NULL,
    `d` date NULL,
    `ts` datetime NULL,
    `v` int NOT NULL
) ENGINE=OLAP
DUPLICATE KEY(`id`)
DISTRIBUTED BY HASH(`id`) BUCKETS 1
PROPERTIES (
    "replication_num" = "1"
);
