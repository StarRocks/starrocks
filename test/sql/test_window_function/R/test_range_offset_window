-- name: test_range_offset_window
CREATE TABLE `test_range_offset_window` (
    `id` int NOT NULL,
    `k` int NULL,
    `d` date NULL,
    `ts` datetime NULL,
    `v` int NOT NULL
) ENGINE=OLAP
DUPLICATE KEY(`id`)
DISTRIBUTED BY HASH(`id`) BUCKETS 1
PROPERTIES (
    "replication_num" = "1"
);
