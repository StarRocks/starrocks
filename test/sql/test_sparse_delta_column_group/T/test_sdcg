-- name: test_sdcg_gin_column_forces_row @cloud
create database test_sdcg_gin;
use test_sdcg_gin;
admin set frontend config ("enable_experimental_gin" = "true");
update information_schema.be_configs set value = "true" where name = "enable_sparse_dcg";
CREATE TABLE t (pk BIGINT NOT NULL, g VARCHAR(32) NOT NULL DEFAULT "",
  INDEX gin_g (g) USING GIN ("parser" = "english"))
PRIMARY KEY(pk) DISTRIBUTED BY HASH(pk) BUCKETS 1 PROPERTIES("replication_num" = "1");
shell: curl --location-trusted -u root: -X PUT -H "Expect:100-continue" -H "column_separator:," -H "columns:pk,g" -T ${root_path}/lib/../common/data/stream_load/sdcg_gin_base.csv ${url}/api/test_sdcg_gin/t/_stream_load
sync;
-- column-mode partial update of the GIN-indexed column: forced to ROW so the inverted index is rebuilt,
-- keeping MATCH correct (pk 1,2 -> 'zulu'; pk 3 stays 'bravo').
shell: curl --location-trusted -u root: -X PUT -H "Expect:100-continue" -H "column_separator:," -H "partial_update:true" -H "partial_update_mode:column" -H "columns:pk,g" -T ${root_path}/lib/../common/data/stream_load/sdcg_gin_upd.csv ${url}/api/test_sdcg_gin/t/_stream_load
sync;
select pk, g from t order by pk;
select pk from t where g match 'zulu' order by pk;
select pk from t where g match 'bravo' order by pk;
select pk from t where g match 'alpha' order by pk;
drop database test_sdcg_gin force;
