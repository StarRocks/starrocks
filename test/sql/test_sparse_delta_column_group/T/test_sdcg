-- name: test_sdcg_column_mode_sparse @cloud
create database test_sdcg_col;
use test_sdcg_col;
update information_schema.be_configs set value = "true" where name = "enable_sparse_dcg";
CREATE TABLE t (pk BIGINT NOT NULL, c1 BIGINT, c2 BIGINT, c3 BIGINT)
PRIMARY KEY(pk) DISTRIBUTED BY HASH(pk) BUCKETS 1 PROPERTIES("replication_num" = "1");
shell: curl --location-trusted -u root: -X PUT -H "Expect:100-continue" -H "column_separator:," -H "columns:pk,c1,c2,c3" -T ${root_path}/lib/../common/data/stream_load/sdcg_base.csv ${url}/api/test_sdcg_col/t/_stream_load
sync;
-- column-mode partial update of c1 only; c2/c3 must be preserved (SDCG sparse write + overlay read)
shell: curl --location-trusted -u root: -X PUT -H "Expect:100-continue" -H "column_separator:," -H "partial_update:true" -H "partial_update_mode:column" -H "columns:pk,c1" -T ${root_path}/lib/../common/data/stream_load/sdcg_upd_col.csv ${url}/api/test_sdcg_col/t/_stream_load
sync;
select * from t order by pk;
drop database test_sdcg_col force;

