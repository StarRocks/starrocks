-- name: test_sdcg_flexible @cloud
create database test_sdcg_flex;
use test_sdcg_flex;
update information_schema.be_configs set value = "true" where name = "enable_sparse_dcg";
CREATE TABLE t (pk BIGINT NOT NULL, c1 BIGINT, c2 BIGINT, c3 BIGINT)
PRIMARY KEY(pk) DISTRIBUTED BY HASH(pk) BUCKETS 1 PROPERTIES("replication_num" = "1");
shell: curl --location-trusted -u root: -X PUT -H "Expect:100-continue" -H "column_separator:," -H "columns:pk,c1,c2,c3" -T ${root_path}/lib/../common/data/stream_load/sdcg_base.csv ${url}/api/test_sdcg_flex/t/_stream_load
sync;
-- flexible: each JSON row updates a DIFFERENT subset; omitted columns keep their existing values
-- row pk=1 -> c1=999 (c2,c3 kept); pk=2 -> c2=888 (c1,c3 kept); pk=3 -> c1=777,c3=777 (c2 kept)
shell: curl --location-trusted -u root: -X PUT -H "Expect:100-continue" -H "format:json" -H "strip_outer_array:true" -H "partial_update:true" -H "partial_update_mode:flexible" -H "columns:pk,c1,c2,c3" -T ${root_path}/lib/../common/data/stream_load/sdcg_flex.json ${url}/api/test_sdcg_flex/t/_stream_load
sync;
select * from t order by pk;
drop database test_sdcg_flex force;

-- name: test_sdcg_flexible_reject_merge_condition @cloud
create database test_sdcg_flex_mc;
use test_sdcg_flex_mc;
CREATE TABLE t (pk BIGINT NOT NULL, c1 BIGINT, c2 BIGINT, c3 BIGINT)
PRIMARY KEY(pk) DISTRIBUTED BY HASH(pk) BUCKETS 1 PROPERTIES("replication_num" = "1");
-- flexible + merge_condition has no flexible-aware apply path -> rejected at plan time
shell: curl --location-trusted -u root: -X PUT -H "Expect:100-continue" -H "format:json" -H "strip_outer_array:true" -H "partial_update:true" -H "partial_update_mode:flexible" -H "merge_condition:c1" -H "columns:pk,c1,c2,c3" -T ${root_path}/lib/../common/data/stream_load/sdcg_flex_one.json ${url}/api/test_sdcg_flex_mc/t/_stream_load
drop database test_sdcg_flex_mc force;

