-- name: test_rejected_records_idempotency @sequential
-- Re-posting the same rejected records (same UUIDs) should not create duplicates
-- thanks to the Primary Key table dedup.

create database db_${uuid0};
use db_${uuid0};
create table t (id int not null, val int not null)
    duplicate key(id) distributed by hash(id) buckets 1
    properties("replication_num" = "1");

shell: { ${mysql_cmd} -Ne "show backends"; ${mysql_cmd} -Ne "show compute nodes"; } | awk '{print $2":"$5}' | sort -u | while read h; do curl -s -X POST "http://$h/api/update_config?rejected_record_sync_interval_sec=5" >/dev/null; curl -s -X POST "http://$h/api/update_config?enable_rejected_record_sync=true" >/dev/null; done; echo "0"

shell: curl -s --location-trusted -u root: -X PUT -H "Expect:100-continue" -H "log_rejected_record_num:-1" -H "label:rej_idem_${uuid0}" -H "strict_mode:true" -H "column_separator:," -d '1,bad_val' ${url}/api/db_${uuid0}/t/_stream_load | jq -r '.Status'

shell: sleep 15

-- Count after first sync
