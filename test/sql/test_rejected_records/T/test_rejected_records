-- name: test_rejected_records_schema @sequential
-- Verify _statistics_.rejected_records exists with the correct 14-column schema.

select TABLE_SCHEMA, TABLE_NAME, TABLE_TYPE
from information_schema.tables
where TABLE_SCHEMA = '_statistics_' and TABLE_NAME = 'rejected_records';

