-- =============================================================
-- Parquet rejection via INSERT FROM FILES (stream load does not accept parquet).
-- Triggers tablet_sink NULL_VIOLATION when cast(string_val AS INT) yields NULL
-- and target column is NOT NULL. Exercises the INSERT load_type path end-to-end.
-- =============================================================

-- name: test_rejected_records_parquet_type_mismatch @sequential
-- INSERT INTO ... SELECT * FROM FILES('format'='parquet'): bad row rejected in tablet_sink.

create database db_${uuid0};
use db_${uuid0};
create table t (id int not null, val int not null, name varchar(64))
    duplicate key(id) distributed by hash(id) buckets 1
    properties("replication_num" = "1");

shell: { ${mysql_cmd} -Ne "show backends"; ${mysql_cmd} -Ne "show compute nodes"; } | awk '{print $2":"$5}' | sort -u | while read h; do curl -s -X POST "http://$h/api/update_config?rejected_record_sync_interval_sec=5" >/dev/null; curl -s -X POST "http://$h/api/update_config?enable_rejected_record_sync=true" >/dev/null; done; echo "0"

-- Generate parquet where val is string; cast to INT will fail on "bad_val" and yield NULL → violates NOT NULL
shell: python3 -c 'import pyarrow as pa, pyarrow.parquet as pq; tbl = pa.table({"id": pa.array([1,2,3],pa.int32()), "val": pa.array(["100","bad_val","200"],pa.string()), "name": pa.array(["alice","bob","carol"],pa.string())}); pq.write_table(tbl, "/tmp/rej_parquet_${uuid0}.parquet"); print(0)'

-- Distribute the parquet file to every CN so the FILES() scan can read it regardless of scheduling
shell: for h in $({ ${mysql_cmd} -Ne "show frontends" | awk '{print $3}'; ${mysql_cmd} -Ne "show compute nodes" | awk '{print $2}'; } | sort -u); do sshpass -p 'sr@test' scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null /tmp/rej_parquet_${uuid0}.parquet sr@$h:/tmp/; done; echo 0

set log_rejected_record_num = -1;
set insert_max_filter_ratio = 1.0;
insert into t select cast(id as int), cast(val as int), name from files('path'='file:///tmp/rej_parquet_${uuid0}.parquet','format'='parquet');

select * from t order by id;

shell: sleep 30

select load_type,
       error_code is not null as has_error_code,
       raw_record is not null as has_raw_record
from _statistics_.rejected_records
where target_database='db_${uuid0}' and target_table='t'
order by created_at limit 5;

shell: { ${mysql_cmd} -Ne "show backends"; ${mysql_cmd} -Ne "show compute nodes"; } | awk '{print $2":"$5}' | sort -u | while read h; do curl -s -X POST "http://$h/api/update_config?enable_rejected_record_sync=false" >/dev/null; curl -s -X POST "http://$h/api/update_config?rejected_record_sync_interval_sec=30" >/dev/null; done; echo "0"
shell: rm -f /tmp/rej_parquet_${uuid0}.parquet; for h in $({ ${mysql_cmd} -Ne "show frontends" | awk '{print $3}'; ${mysql_cmd} -Ne "show compute nodes" | awk '{print $2}'; } | sort -u); do sshpass -p 'sr@test' ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null sr@$h "rm -f /tmp/rej_parquet_${uuid0}.parquet" >/dev/null 2>&1; done; echo 0
drop database db_${uuid0};

-- =============================================================
-- ORC via INSERT FROM FILES: regression guard for the "feature limit"
-- -------------------------------------------------------------
-- OrcChunkReader does not yet have a per-row error-capture path the way the
-- Parquet arrow converter does (arrow_to_starrocks_converter.report_error_message
-- feeds RejectedRecordWriter::append_from_slices). BE therefore rejects the
-- whole query with error 5609 when ORC is combined with log_rejected_record_num.
-- This case captures that status. If ORC grows a per-row capture path in the
-- future, the insert will succeed and the assertion block below will show
-- actual rejected rows — the R diff is the signal to update the expectation.
-- =============================================================

-- name: test_rejected_records_orc_type_mismatch @sequential
-- INSERT INTO ... FROM FILES('format'='orc') with log_rejected_record_num is
-- rejected by the BE today (error 5609). See comment block above.

create database db_${uuid0};
use db_${uuid0};
create table t (id int not null, val int not null, name varchar(64))
    duplicate key(id) distributed by hash(id) buckets 1
    properties("replication_num" = "1");

shell: { ${mysql_cmd} -Ne "show backends"; ${mysql_cmd} -Ne "show compute nodes"; } | awk '{print $2":"$5}' | sort -u | while read h; do curl -s -X POST "http://$h/api/update_config?rejected_record_sync_interval_sec=5" >/dev/null; curl -s -X POST "http://$h/api/update_config?enable_rejected_record_sync=true" >/dev/null; done; echo "0"

shell: python3 -c 'import pyorc, io; schema = "struct<id:int,val:string,name:string>"; buf = io.BytesIO(); w = pyorc.Writer(buf, schema); w.write((1, "100", "alice")); w.write((2, "bad_val", "bob")); w.write((3, "200", "carol")); w.close(); open("/tmp/rej_orc_${uuid0}.orc","wb").write(buf.getvalue()); print(0)'

shell: for h in $({ ${mysql_cmd} -Ne "show frontends" | awk '{print $3}'; ${mysql_cmd} -Ne "show compute nodes" | awk '{print $2}'; } | sort -u); do sshpass -p 'sr@test' scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null /tmp/rej_orc_${uuid0}.orc sr@$h:/tmp/; done; echo 0

set log_rejected_record_num = -1;
set insert_max_filter_ratio = 1.0;
insert into t select cast(id as int), cast(val as int), name from files('path'='file:///tmp/rej_orc_${uuid0}.orc','format'='orc');

select * from t order by id;

shell: sleep 30

select load_type,
       error_code is not null as has_error_code,
       raw_record is not null as has_raw_record
from _statistics_.rejected_records
where target_database='db_${uuid0}' and target_table='t'
order by created_at limit 5;

shell: { ${mysql_cmd} -Ne "show backends"; ${mysql_cmd} -Ne "show compute nodes"; } | awk '{print $2":"$5}' | sort -u | while read h; do curl -s -X POST "http://$h/api/update_config?enable_rejected_record_sync=false" >/dev/null; curl -s -X POST "http://$h/api/update_config?rejected_record_sync_interval_sec=30" >/dev/null; done; echo "0"
shell: rm -f /tmp/rej_orc_${uuid0}.orc; for h in $({ ${mysql_cmd} -Ne "show frontends" | awk '{print $3}'; ${mysql_cmd} -Ne "show compute nodes" | awk '{print $2}'; } | sort -u); do sshpass -p 'sr@test' ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null sr@$h "rm -f /tmp/rej_orc_${uuid0}.orc" >/dev/null 2>&1; done; echo 0
