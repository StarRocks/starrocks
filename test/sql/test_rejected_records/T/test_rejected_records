-- name: test_rejected_records_insert @sequential
-- INSERT INTO ... SELECT with NULL violations produces rejected records tagged as INSERT.
-- Exercises the FE path that sets TQueryType.LOAD for INSERT and the BE tablet_sink NULL_VIOLATION branch.

create database db_${uuid0};
use db_${uuid0};

-- Source table holds string representations; cast('abc' as int) returns NULL and violates NOT NULL on dst.
create table src (id int not null, val varchar(16) not null)
    duplicate key(id) distributed by hash(id) buckets 1
    properties("replication_num" = "1");
insert into src values (1,'100'),(2,'abc'),(3,'200');

create table dst (id int not null, val int not null)
