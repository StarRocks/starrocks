2020-11-10	1	1
2020-11-11	2	2
2020-11-12	3	3
-- !result

-- Second refresh without explicit FORCE - should refresh because config=4 affects list partitioned MVs
REFRESH MATERIALIZED VIEW test_mv4 WITH SYNC MODE;
-- result:
-- !result
select * from test_mv4 order by k1, k2;
-- result:
2020-11-10	1	1
2020-11-11	2	2
2020-11-12	3	3
-- !result

DROP MATERIALIZED VIEW test_mv4;
-- result:
-- !result
drop table t3;
