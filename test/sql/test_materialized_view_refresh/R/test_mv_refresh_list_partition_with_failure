-- name: test_mv_refresh_list_partition_with_failure @sequential
-- Test that when an MV refresh fails, the original data is preserved.
-- This test verifies the fix for the issue where MV refresh failure was
-- causing the MV to end up with 0 rows.
create database db_${uuid0};
-- result:
-- !result
use db_${uuid0};
-- result:
-- !result
CREATE TABLE t1 (
    id BIGINT,
    province VARCHAR(64) not null,
    age SMALLINT,
    dt VARCHAR(10)
)
DUPLICATE KEY(id)
PARTITION BY LIST (province) (
    PARTITION p1 VALUES IN ("beijing"),
    PARTITION p2 VALUES IN ("guangdong")
)
DISTRIBUTED BY RANDOM
PROPERTIES ('replication_num' = '1');
-- result:
-- !result
INSERT INTO t1 VALUES (1, 'beijing', 10, '2021-12-01'), (2, 'guangdong', 20, '2021-12-02');
-- result:
-- !result
-- Create MV
CREATE MATERIALIZED VIEW mv1
PARTITION BY province
REFRESH DEFERRED MANUAL
DISTRIBUTED BY RANDOM
PROPERTIES ('replication_num' = '1')
AS SELECT dt, province, sum(age) as total_age FROM t1 GROUP BY dt, province;
-- result:
-- !result
-- Initial refresh
REFRESH MATERIALIZED VIEW mv1 WITH SYNC MODE;
-- result:
-- !result
-- Verify MV has data
SELECT * FROM mv1 ORDER BY province;
-- result:
-- 2021-12-01	beijing	10
-- 2021-12-02	guangdong	20
-- !result
-- Get row count before failure
SELECT count(*) as cnt FROM mv1;
-- result:
-- 2
-- !result
-- Add new data to trigger a refresh
INSERT INTO t1 VALUES (3, 'beijing', 30, '2021-12-03');
-- result:
-- !result
-- Enable fail point to simulate refresh failure after partition sync but before insert
ADMIN ENABLE FAILPOINT 'MV_REFRESH_INJECT_FAILURE';
-- result:
-- !result
-- This refresh should fail due to injected failure
-- [UC] means the command may fail
[UC] REFRESH MATERIALIZED VIEW mv1;
-- result:
-- E: (1064, "Injected failure for MV refresh testing")
-- !result
-- Disable fail point
ADMIN DISABLE FAILPOINT 'MV_REFRESH_INJECT_FAILURE';
-- result:
-- !result
-- Verify MV still has the original data (not 0 rows)
-- This is the key assertion - after refresh failure, MV should retain original data
SELECT count(*) as cnt FROM mv1;
-- result:
-- 2
-- !result
-- Now do a successful refresh
REFRESH MATERIALIZED VIEW mv1 WITH SYNC MODE;
-- result:
-- !result
-- Verify MV has updated data after successful refresh
SELECT * FROM mv1 ORDER BY province;
-- result:
-- 2021-12-01	beijing	10
-- 2021-12-03	beijing	30
-- 2021-12-02	guangdong	20
-- !result
-- Cleanup
DROP MATERIALIZED VIEW mv1;
-- result:
-- !result
DROP TABLE t1;
-- result:
-- !result
DROP DATABASE db_${uuid0};
-- result:
-- !result
CLEANUP {
    ADMIN DISABLE FAILPOINT 'MV_REFRESH_INJECT_FAILURE';
} END CLEANUP
-- result:
-- !result
