-- name: test_materialize_basic_types
-- Test materialize() with basic scalar types
select materialize(true);
-- result:
1
-- !result
select materialize(cast(1 as tinyint));
-- result:
1
-- !result
select materialize(cast(2 as smallint));
-- result:
2
-- !result
select materialize(cast(3 as int));
-- result:
3
-- !result
select materialize(cast(4 as bigint));
-- result:
4
-- !result
select materialize(cast(5 as largeint));
-- result:
5
-- !result
select materialize(cast(1.5 as float));
-- result:
1.5
-- !result
select materialize(cast(2.5 as double));
-- result:
2.5
-- !result
select materialize('hello');
-- result:
hello
-- !result
select materialize(cast('2024-01-01' as date));
-- result:
2024-01-01
-- !result
select materialize(cast('2024-01-01 12:00:00' as datetime));
-- result:
2024-01-01 12:00:00
-- !result
select materialize(cast(3.14 as decimal(10, 2)));
-- result:
3.14
-- !result
select materialize(parse_json('{"a": 1}'));
-- result:
{"a": 1}
-- !result
select materialize(cast('binary' as varbinary));
-- result:
binary
-- !result
-- name: test_materialize_null
-- Test materialize() with NULL input
select materialize(null);
-- result:
None
-- !result
select materialize(cast(null as int));
-- result:
None
-- !result
select materialize(cast(null as varchar));
-- result:
None
-- !result
select materialize(cast(null as date));
-- result:
None
-- !result
-- name: test_materialize_expression
-- Test materialize() preserves expression results
select materialize(1 + 2);
-- result:
3
-- !result
select materialize(concat('hello', ' ', 'world'));
-- result:
hello world
-- !result
select materialize(cast('2024-06-15' as date) > cast('2024-01-01' as date));
-- result:
1
-- !result
-- name: test_materialize_nested
-- Test nested materialize() calls
select materialize(materialize(42));
-- result:
42
-- !result
select materialize(materialize('nested'));
-- result:
nested
-- !result
-- name: test_materialize_on_table
-- Test materialize() against table columns (predicate / select / aggregate)
create database test_db_${uuid0};
-- result:
-- !result
use test_db_${uuid0};
-- result:
-- !result
create table t1 (c1 int, c2 varchar(64), c3 date) properties("replication_num" = "1");
-- result:
-- !result
insert into t1 values (1, 'aaa', '2024-01-01'), (2, 'bbb', '2024-06-15'), (3, 'ccc', '2024-12-31');
-- result:
-- !result
select * from t1 where materialize(c1) > 1 order by c1;
-- result:
2	bbb	2024-06-15
3	ccc	2024-12-31
-- !result
select * from t1 where materialize(c2) = 'bbb';
-- result:
2	bbb	2024-06-15
-- !result
select * from t1 where materialize(c3) >= '2024-06-01' order by c1;
-- result:
2	bbb	2024-06-15
3	ccc	2024-12-31
-- !result
select * from t1 where materialize(c1) in (1, 3) order by c1;
-- result:
1	aaa	2024-01-01
3	ccc	2024-12-31
-- !result
select materialize(c1), materialize(c2), materialize(c3) from t1 order by c1;
-- result:
1	aaa	2024-01-01
2	bbb	2024-06-15
3	ccc	2024-12-31
-- !result
select sum(materialize(c1)), count(materialize(c2)) from t1;
-- result:
6	3
-- !result
drop database test_db_${uuid0};
