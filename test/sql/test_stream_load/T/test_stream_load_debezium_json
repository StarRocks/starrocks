-- name: test_stream_load_debezium
create database db_${uuid0};
use db_${uuid0};

-- test_debezium_payload
CREATE TABLE t1 (
    id INT NOT NULL,
    name VARCHAR(100),
    age INT
) PRIMARY KEY (id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1");

shell: curl -s --location-trusted -u root: -H "Expect:100-continue" -H "format: json" -H "envelope: debezium" -d '{"payload":{"before":null,"after":{"id":1,"name":"Alice","age":25},"op":"c"}} {"payload":{"before":null,"after":{"id":2,"name":"Bob","age":30},"op":"r"}} {"payload":{"before":{"id":3,"name":"Old","age":0},"after":{"id":3,"name":"Charlie","age":35},"op":"u"}}' -XPUT ${url}/api/db_${uuid0}/t1/_stream_load | jq -r '.Status'

sync;

select * from t1 order by id;

drop table t1;


