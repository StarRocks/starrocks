-- name: test_merge_commit_debezium_json
create database db_${uuid0};
use db_${uuid0};

CREATE TABLE t1 (
    id INT NOT NULL,
    name VARCHAR(100),
    age INT
) PRIMARY KEY (id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1");

CONCURRENCY {

-- thread name 1:
shell: curl --location-trusted -u root: -X PUT -H "Expect:100-continue" -H "format: json" -H "envelope: debezium" -H "enable_merge_commit:true" -H "merge_commit_interval_ms:1000" -H "merge_commit_parallel:4" -d '{"payload":{"before":null,"after":{"id":1,"name":"Alice","age":25},"op":"c"}}' ${url}/api/db_${uuid0}/t1/_stream_load

-- thread name 2:
shell: curl --location-trusted -u root: -X PUT -H "Expect:100-continue" -H "format: json" -H "envelope: debezium" -H "enable_merge_commit:true" -H "merge_commit_interval_ms:1000" -H "merge_commit_parallel:4" -d '{"payload":{"before":null,"after":{"id":2,"name":"Bob","age":30},"op":"c"}}' ${url}/api/db_${uuid0}/t1/_stream_load

} END CONCURRENCY

function: wait_db_transaction_finish("db_${uuid0}", 60)

sync;
select * from t1 order by id;

drop database db_${uuid0};
