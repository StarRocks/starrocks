-- name: test_iceberg_variant_virtual_column_rewrite

create external catalog iceberg_variant_vc_test_${uuid0}
PROPERTIES (
    "type"="iceberg",
    "iceberg.catalog.type"="hadoop",
    "iceberg.catalog.warehouse"="oss://${oss_bucket}/test_iceberg_variant_virtual_column_rewrite/${uuid0}/warehouse/"
);

shell: ossutil64 mkdir oss://${oss_bucket}/test_iceberg_variant_virtual_column_rewrite/${uuid0}/warehouse/zya > /dev/null

use iceberg_variant_vc_test_${uuid0}.zya;

CREATE TABLE test_variant_virtual_column (
    data VARIANT
) properties(
  'format-version' = '3',
  'iceberg.enableVariantShredding' = 'true'
);

shell: ossutil64 cp ../be/test/formats/parquet/test_data/variant_shredding.parquet oss://${oss_bucket}/test_iceberg_variant_virtual_column_rewrite/${uuid0}/data/shredding.parquet > /dev/null

alter table test_variant_virtual_column execute add_files(location='oss://${oss_bucket}/test_iceberg_variant_virtual_column_rewrite/${uuid0}/data/shredding.parquet', file_format='parquet');

set cbo_variant_path_rewrite = false;
function: assert_explain_not_contains("select get_variant_int(data, '$.id') from test_variant_virtual_column", "ExtendedColumnAccessPath")

set cbo_variant_path_rewrite = true;
function: assert_explain_verbose_contains("select get_variant_int(data, '$.id') as id, get_variant_string(data, '$.profile.department') as dept from test_variant_virtual_column", "ColumnAccessPath: [/data/id(bigint(20)), /data/profile/department(varchar)]")
function: assert_explain_verbose_contains("select get_variant_int(data, '$.id') from test_variant_virtual_column", "ExtendedColumnAccessPath: [/data(bigint(20))/id(bigint(20))]")
function: assert_explain_verbose_contains("select cast(variant_query(data, '$.profile.rank') as bigint) from test_variant_virtual_column", "ExtendedColumnAccessPath: [/data(bigint(20))/profile(bigint(20))/rank(bigint(20))]")
function: assert_explain_verbose_contains("select sum(get_variant_int(data, '$.profile.metrics.views')) from test_variant_virtual_column", "ExtendedColumnAccessPath: [/data(bigint(20))/profile(bigint(20))/metrics(bigint(20))/views(bigint(20))]")

shell: ossutil64 rm -rf oss://${oss_bucket}/test_iceberg_variant_virtual_column_rewrite/${uuid0}/ > /dev/null

drop table test_variant_virtual_column force;
set catalog default_catalog;
drop catalog iceberg_variant_vc_test_${uuid0};
