[ORDER]SELECT s, m, rn
FROM (
  SELECT t.s, r.m,
         row_number() over (partition by t.s order by t.s, r.m) rn
  FROM (
    SELECT pid, s
    FROM (
      SELECT pid, s, lead(s, 1, 'NONE') over (partition by pid order by ts) nxt
      FROM topn_decoded_fact
    ) x
    WHERE nxt != 'ZZZ'
  ) t
  LEFT JOIN topn_decoded_map r ON r.pid = t.pid
) y
WHERE rn = 1
