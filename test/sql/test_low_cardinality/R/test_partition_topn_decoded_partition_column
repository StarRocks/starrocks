-- result:
None
-- !result
[ORDER]SELECT s, m, rn
FROM (
  SELECT t.s, r.m,
         row_number() over (partition by t.s order by t.s, r.m) rn
  FROM (
    SELECT pid, s
    FROM (
      SELECT pid, s, row_number() over (partition by s order by ts) rn2
      FROM topn_decoded_fact
    ) x
    WHERE rn2 = 1
  ) t
  LEFT JOIN topn_decoded_map r ON r.pid = t.pid
) y
WHERE rn = 1
ORDER BY s;
-- result:
S0	M0	1
S1	M1	1
