DUPLICATE KEY(id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1");

-- DDL rejection: invalid quantizer name
CREATE TABLE t_hnsw_bad_quantizer (
  id bigint NOT NULL,
  vec ARRAY<float> NOT NULL,
