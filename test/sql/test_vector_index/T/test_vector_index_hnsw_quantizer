  )
) ENGINE=OLAP
DUPLICATE KEY(id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1");

-- DDL rejection: m_pq does not divide dim
CREATE TABLE t_hnsw_pq_bad_m (
  id bigint NOT NULL,
  vec ARRAY<float> NOT NULL,
  INDEX vec_idx (vec) USING VECTOR (
    "index_type" = "hnsw",
