DUPLICATE KEY(id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1");

-- Cleanup
DROP TABLE IF EXISTS t_hnsw_sq8;
DROP TABLE IF EXISTS t_hnsw_sq4;
DROP TABLE IF EXISTS t_hnsw_pq;
DROP TABLE IF EXISTS t_hnsw_pq_missing_m;
