-- HNSW + PQ: requires m_pq (must divide dim)
CREATE TABLE t_hnsw_pq (
  id bigint NOT NULL,
  vec ARRAY<float> NOT NULL,
  INDEX vec_idx (vec) USING VECTOR (
    "index_type" = "hnsw",
    "dim" = "8",
    "metric_type" = "l2_distance",
    "is_vector_normed" = "false",
    "M" = "16",
    "efconstruction" = "40",
    "quantizer" = "pq",
    "m_pq" = "4",
    "nbits_pq" = "8"
  )
) ENGINE=OLAP
DUPLICATE KEY(id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1");

-- DDL rejection: PQ without m_pq
CREATE TABLE t_hnsw_pq_missing_m (
  id bigint NOT NULL,
  vec ARRAY<float> NOT NULL,
  INDEX vec_idx (vec) USING VECTOR (
    "index_type" = "hnsw",
    "dim" = "8",
