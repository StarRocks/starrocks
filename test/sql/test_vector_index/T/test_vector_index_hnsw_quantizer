-- name: test_vector_index_hnsw_quantizer @sequential @native

ADMIN SET FRONTEND CONFIG("enable_experimental_vector" = "true");

-- =====================================================================
-- HNSW + quantizer DDL: SQ4 / SQ8 / PQ acceptance
-- Covers the FE analyzer path (quantizer / m_pq / nbits_pq properties)
-- end-to-end through index build and top-K query.
-- =====================================================================

-- HNSW + SQ8 (most common quantizer)
CREATE TABLE t_hnsw_sq8 (
  id bigint NOT NULL,
  vec ARRAY<float> NOT NULL,
  INDEX vec_idx (vec) USING VECTOR (
    "index_type" = "hnsw",
    "dim" = "4",
    "metric_type" = "l2_distance",
    "is_vector_normed" = "false",
    "M" = "16",
    "efconstruction" = "40",
    "quantizer" = "sq8"
  )
) ENGINE=OLAP
DUPLICATE KEY(id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1");

INSERT INTO t_hnsw_sq8 VALUES
  (1, [1.0, 0.0, 0.0, 0.0]),
  (2, [0.0, 1.0, 0.0, 0.0]),
  (3, [0.0, 0.0, 1.0, 0.0]),
  (4, [0.0, 0.0, 0.0, 1.0]);

SELECT id FROM t_hnsw_sq8
  ORDER BY approx_l2_distance([1.0, 0.0, 0.0, 0.0], vec)
  LIMIT 1;

