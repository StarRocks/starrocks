-- name: test_files_schema_partition

create database db_${uuid0};
use db_${uuid0};

shell: ossutil64 mkdir oss://${oss_bucket}/test_files/parquet_format/${uuid0}/dt=2026-04-21/region=us/ >/dev/null || echo "exit 0" >/dev/null
shell: ossutil64 cp --force ./sql/test_files/parquet_format/basic_type.parquet oss://${oss_bucket}/test_files/parquet_format/${uuid0}/dt=2026-04-21/region=us/ | grep -Pv "(average|elapsed)"

-- Compatible case: schema columns lead, path columns trail
select k2, k7, dt, region from files(
    "path" = "oss://${oss_bucket}/test_files/parquet_format/${uuid0}/*/*/*",
    "format" = "parquet",
    "aws.s3.access_key" = "${oss_ak}",
    "aws.s3.secret_key" = "${oss_sk}",
    "aws.s3.endpoint" = "${oss_endpoint}",
    "columns_from_path" = "dt,region",
    "schema" = "k2 BIGINT, k7 VARCHAR(64)")
order by k2 limit 3;

-- Conflict case: schema declares 'dt' which also comes from path
select * from files(
    "path" = "oss://${oss_bucket}/test_files/parquet_format/${uuid0}/*/*/*",
    "format" = "parquet",
    "aws.s3.access_key" = "${oss_ak}",
    "aws.s3.secret_key" = "${oss_sk}",
    "aws.s3.endpoint" = "${oss_endpoint}",
    "columns_from_path" = "dt,region",
    "schema" = "dt BIGINT, k7 VARCHAR(64)");

shell: ossutil64 rm -rf oss://${oss_bucket}/test_files/parquet_format/${uuid0}/ > /dev/null
