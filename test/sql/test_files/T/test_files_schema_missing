-- name: test_files_schema_missing

create database db_${uuid0};
use db_${uuid0};

-- Top-level missing column, fill=null → NULLs
shell: ossutil64 cp --force ./sql/test_files/parquet_format/basic_type.parquet oss://${oss_bucket}/test_files/parquet_format/${uuid0}/ | grep -Pv "(average|elapsed)"
select k2, nonexistent from files(
    "path" = "oss://${oss_bucket}/test_files/parquet_format/${uuid0}/*",
    "format" = "parquet",
    "aws.s3.access_key" = "${oss_ak}",
    "aws.s3.secret_key" = "${oss_sk}",
    "aws.s3.endpoint" = "${oss_endpoint}",
    "fill_mismatch_column_with" = "null",
    "schema" = "k2 INT, nonexistent VARCHAR(64)")
order by k2 limit 3;

-- Top-level missing column, fill=none (default) → query error
select nonexistent from files(
    "path" = "oss://${oss_bucket}/test_files/parquet_format/${uuid0}/*",
    "format" = "parquet",
    "aws.s3.access_key" = "${oss_ak}",
    "aws.s3.secret_key" = "${oss_sk}",
    "aws.s3.endpoint" = "${oss_endpoint}",
    "schema" = "nonexistent VARCHAR(64)");

-- Nested missing subfield, ORC, fill=none → error (stable regardless of
-- the ORC bugfix state; nested+fill=null variant is deferred to the follow-up PR).
shell: ossutil64 cp --force ./sql/test_files/orc_format/struct_mix.snappy.orc oss://${oss_bucket}/test_files/orc_format/${uuid0}/ | grep -Pv "(average|elapsed)"
select col_struct.c_int from files(
    "path" = "oss://${oss_bucket}/test_files/orc_format/${uuid0}/*",
    "format" = "orc",
    "aws.s3.access_key" = "${oss_ak}",
    "aws.s3.secret_key" = "${oss_sk}",
    "aws.s3.endpoint" = "${oss_endpoint}",
    "schema" = "col_struct STRUCT<c_int INT, c_missing BIGINT>");

shell: ossutil64 rm -rf oss://${oss_bucket}/test_files/parquet_format/${uuid0}/ > /dev/null
shell: ossutil64 rm -rf oss://${oss_bucket}/test_files/orc_format/${uuid0}/ > /dev/null
