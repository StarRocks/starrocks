-- name: test_builtin_sv_no_lock_leak @cloud
-- Regression test for DB read lock leak in getBindingsOfBuiltinStorageVolume().
-- Scenario: one DB is explicitly bound to a custom SV (dbToStorageVolume has an entry);
-- another DB has no explicit binding (uses builtin_storage_volume implicitly).
-- Triggering DROP STORAGE VOLUME builtin_storage_volume calls getBindingsOfBuiltinStorageVolume(),
-- which in the old code would acquire a READ lock on the explicitly-bound DB and then skip the
-- unlock via `continue`, permanently leaking the lock.  Any subsequent DDL on that DB requiring
-- a WRITE lock would then hang indefinitely.  With the fix the lock is never taken for that DB,
-- so the subsequent CREATE TABLE completes immediately.
CREATE STORAGE VOLUME IF NOT EXISTS sv_${uuid0} type = s3 LOCATIONS = ('s3://${oss_bucket}/test_sv_lock_${uuid0}') COMMENT 'lock leak regression test sv' PROPERTIES ("aws.s3.endpoint"="${oss_endpoint}", "aws.s3.region"="${oss_region}", "aws.s3.use_aws_sdk_default_behavior" = "false", "enabled"="true", "aws.s3.access_key" = "${oss_ak}", "aws.s3.secret_key" = "${oss_sk}");
-- db_bound is explicitly bound to sv_${uuid0}, so dbToStorageVolume[db_bound] is set.
-- getBindingsOfBuiltinStorageVolume() skips it (does not count it as a builtin binding).
-- Old code: acquired READ lock on db_bound then continued without releasing — lock leaked.
-- New code: containsKey check fires before any lock is taken — no leak.
CREATE DATABASE db_bound_${uuid0} PROPERTIES("storage_volume" = "sv_${uuid0}");
-- db_builtin has no explicit SV binding and therefore implicitly uses builtin_storage_volume.
-- Its presence ensures the DROP below fails at the "is referenced" check, which is reached
-- only after getBindingsOfBuiltinStorageVolume() has already run (and leaked in the old code).
CREATE DATABASE db_builtin_${uuid0};
-- Make sv_${uuid0} the default so that builtin_storage_volume is no longer the default.
-- This is required: without it, DROP STORAGE VOLUME builtin_storage_volume fails immediately
-- with "default storage volume can not be removed" before getBindingsOfBuiltinStorageVolume()
-- is ever called, so the lock-leak path would never be exercised.
SET sv_${uuid0} AS DEFAULT STORAGE VOLUME;
-- Attempt to drop builtin_storage_volume.  This call reaches getBindingsOfBuiltinStorageVolume(),
-- which exercises the fixed code path for db_bound_${uuid0}.  The drop then fails because
-- db_builtin_${uuid0} is still implicitly bound to the builtin SV.
DROP STORAGE VOLUME builtin_storage_volume;
-- CREATE TABLE requires a WRITE lock on db_bound_${uuid0}.
-- With the old (buggy) code this hangs indefinitely because db_bound's READ lock was leaked.
-- With the fix this completes immediately, proving there is no lock leak.
CREATE TABLE db_bound_${uuid0}.t1 (k1 INT, v1 VARCHAR(10)) DISTRIBUTED BY HASH(k1) BUCKETS 1;
-- cleanup: unbind db_bound from sv_${uuid0} before dropping, then reset the default SV
ALTER DATABASE db_bound_${uuid0} SET("storage_volume" = "builtin_storage_volume");
DROP DATABASE db_bound_${uuid0} FORCE;
DROP DATABASE db_builtin_${uuid0} FORCE;
shell: sleep 5
SET builtin_storage_volume AS DEFAULT STORAGE VOLUME;
DROP STORAGE VOLUME sv_${uuid0};
