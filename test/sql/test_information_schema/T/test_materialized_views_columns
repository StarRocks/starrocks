-- name: test_materialized_views_columns
create database db_${uuid0};
use db_${uuid0};
create table base_t (dt date, v int) duplicate key(dt)
partition by range(dt) (partition p1 values [('2024-01-01'),('2024-01-02')), partition p2 values [('2024-01-02'),('2024-01-03')))
distributed by hash(dt) buckets 2 properties('replication_num'='1');
insert into base_t values ('2024-01-01',1),('2024-01-02',2);
create materialized view mv_manual partition by dt distributed by hash(dt)
refresh deferred manual
as select dt, sum(v) sv from base_t group by dt;

-- LAST_FRESHNESS_CONFIRMED_AT is NULL until the first successful refresh.
select if(LAST_FRESHNESS_CONFIRMED_AT is null, 'OK', concat('FAILED: ', LAST_FRESHNESS_CONFIRMED_AT))
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_manual';
refresh materialized view mv_manual with sync mode;
select if(LAST_FRESHNESS_CONFIRMED_AT is not null, 'OK', 'FAILED')
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_manual';

-- A no-change refresh is SKIPPED yet still confirms freshness and advances the column.
[UC]t1=select LAST_FRESHNESS_CONFIRMED_AT from information_schema.materialized_views where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_manual';
select sleep(2);
refresh materialized view mv_manual with sync mode;
select if(LAST_FRESHNESS_CONFIRMED_AT > '${t1}', 'OK', 'FAILED')
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_manual';

-- A partition-scoped (partial) refresh must NOT confirm whole-MV freshness.
create table pt (dt date, v int) duplicate key(dt)
partition by range(dt) (partition p1 values [('2024-01-01'),('2024-01-02')), partition p2 values [('2024-01-02'),('2024-01-03')))
distributed by hash(dt) buckets 2 properties('replication_num'='1');
insert into pt values ('2024-01-01',1),('2024-01-02',2);
create materialized view mv_part partition by dt distributed by hash(dt)
refresh deferred manual
as select dt, sum(v) sv from pt group by dt;
REFRESH MATERIALIZED VIEW mv_part PARTITION START ("2024-01-01") END ("2024-01-02") WITH SYNC MODE;
select if(LAST_FRESHNESS_CONFIRMED_AT is null, 'OK', concat('FAILED: ', LAST_FRESHNESS_CONFIRMED_AT))
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_part';
refresh materialized view mv_part with sync mode;
select if(LAST_FRESHNESS_CONFIRMED_AT is not null, 'OK', 'FAILED')
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_part';

-- The column is exposed as DATETIME in information_schema (FE table + BE scanner schema guard).
select if(count(*) = 1, 'OK', 'FAILED')
from information_schema.columns
where table_schema = 'information_schema' and table_name = 'materialized_views'
  and column_name = 'LAST_FRESHNESS_CONFIRMED_AT' and data_type = 'datetime';

-- SHOW MATERIALIZED VIEWS surfaces the column as the trailing datetime (SHOW-rewrite-to-SELECT path).
show materialized views where name = 'mv_manual';

-- Both read paths return the column: FE-evaluated scan (rule on) and BE scanner (rule off).
set enable_evaluate_schema_scan_rule = true;
select if(LAST_FRESHNESS_CONFIRMED_AT is not null, 'OK', 'FAILED')
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_manual';
set enable_evaluate_schema_scan_rule = false;
select if(LAST_FRESHNESS_CONFIRMED_AT is not null, 'OK', 'FAILED')
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_manual';
set enable_evaluate_schema_scan_rule = true;

-- FORCE refresh (no data change) still confirms freshness.
[UC]t2=select LAST_FRESHNESS_CONFIRMED_AT from information_schema.materialized_views where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_manual';
select sleep(2);
refresh materialized view mv_manual force with sync mode;
select if(LAST_FRESHNESS_CONFIRMED_AT > '${t2}', 'OK', 'FAILED')
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_manual';

-- Multi-batch refresh (partition_refresh_number) confirms freshness once the final batch completes.
alter materialized view mv_manual set ('partition_refresh_number' = '1');
[UC]t3=select LAST_FRESHNESS_CONFIRMED_AT from information_schema.materialized_views where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_manual';
select sleep(2);
refresh materialized view mv_manual force with sync mode;
select if(LAST_FRESHNESS_CONFIRMED_AT > '${t3}', 'OK', 'FAILED')
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_manual';

-- Non-partitioned MV: NULL before, set after a complete refresh.
create materialized view mv_np distributed by hash(dt)
refresh deferred manual
as select dt, sum(v) sv from base_t group by dt;
select if(LAST_FRESHNESS_CONFIRMED_AT is null, 'OK', concat('FAILED: ', LAST_FRESHNESS_CONFIRMED_AT))
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_np';
refresh materialized view mv_np with sync mode;
select if(LAST_FRESHNESS_CONFIRMED_AT is not null, 'OK', 'FAILED')
from information_schema.materialized_views
where TABLE_SCHEMA = 'db_${uuid0}' and TABLE_NAME = 'mv_np';
drop database db_${uuid0} force;
