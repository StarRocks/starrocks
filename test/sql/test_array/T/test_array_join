-- name: test_array_join

CREATE TABLE `student_score` (
  `id` bigint(20) NULL COMMENT "",
  `scores` array<int(11)> NULL COMMENT ""
) ENGINE=OLAP
DUPLICATE KEY(`id`)
DISTRIBUTED BY HASH(`id`)
PROPERTIES (
"replication_num" = "1"
);

INSERT INTO student_score VALUES
(1, [80,85,87]),
