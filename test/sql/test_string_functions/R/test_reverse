-- implicit cast via table columns
create table t_reverse_types(
    id int,
    c_int int,
    c_bigint bigint,
    c_boolean boolean,
    c_date date,
    c_datetime datetime,
    c_double double,
    c_decimal decimal(20,3)
) DUPLICATE KEY(id)
  DISTRIBUTED BY HASH(id)
  BUCKETS 1
  PROPERTIES('replication_num'='1');
