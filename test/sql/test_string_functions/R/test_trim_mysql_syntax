-- name: test_trim_mysql_syntax
CREATE DATABASE IF NOT EXISTS test_trim_mysql_syntax_db;
-- result:
-- !result
USE test_trim_mysql_syntax_db;
-- result:
-- !result
SELECT TRIM('  bar   ');
-- result:
bar
-- !result
SELECT TRIM(BOTH FROM '  bar  ');
-- result:
bar
-- !result
SELECT TRIM(LEADING FROM '  bar');
-- result:
bar
-- !result
SELECT TRIM(TRAILING FROM 'bar  ');
-- result:
bar
-- !result
SELECT TRIM(BOTH 'x' FROM 'xxxbarxxx');
-- result:
bar
-- !result
SELECT TRIM(LEADING 'x' FROM 'xxxbarxxx');
-- result:
barxxx
-- !result
SELECT TRIM(TRAILING 'x' FROM 'xxxbarxxx');
-- result:
xxxbar
-- !result
SELECT TRIM('x' FROM 'xxxbarxxx');
-- result:
bar
-- !result
SELECT TRIM(TRAILING 'xyz' FROM 'barxxyz');
-- result:
barx
-- !result
SELECT TRIM(TRAILING 'xyz' FROM 'barxxyzxyz');
-- result:
barx
-- !result
SELECT TRIM(LEADING 'ab' FROM 'ababfoo');
-- result:
foo
-- !result
SELECT TRIM(BOTH 'ab' FROM 'abfooab');
-- result:
foo
-- !result
SELECT TRIM(BOTH '' FROM 'abc');
-- result:
abc
-- !result
SELECT leading FROM (SELECT 1 AS leading) t;
-- result:
1
-- !result
CREATE TABLE t_trim_src(id INT, c VARCHAR(65533), c2 VARCHAR(65533))
        DUPLICATE KEY(id)
        DISTRIBUTED BY HASH(id)
        BUCKETS 1
        PROPERTIES('replication_num'='1');
-- result:
-- !result
INSERT INTO t_trim_src VALUES
    (1, 'xxxbarxxx', 'xyz'),
    (2, 'xyzfooxyz', 'abc'),
    (3, NULL,        'def');
-- result:
-- !result
SELECT TRIM(LEADING 'x' FROM c) FROM t_trim_src ORDER BY id;
-- result:
barxxx
yzfooxyz
None
-- !result
SELECT TRIM(TRAILING 'xyz' FROM c) FROM t_trim_src ORDER BY id;
-- result:
xxxbarxxx
xyzfoo
None
-- !result
SELECT TRIM('x' FROM c) FROM t_trim_src ORDER BY id;
-- result:
bar
yzfooxyz
None
-- !result
SELECT TRIM(LEADING 'xyz' FROM concat(c, c2)) FROM t_trim_src WHERE c IS NOT NULL ORDER BY id;
-- result:
xxxbarxxxxyz
fooxyzabc
-- !result
SELECT TRIM('x' FROM CAST(NULL AS STRING));
-- result:
None
