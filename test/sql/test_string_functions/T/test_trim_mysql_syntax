-- name: test_trim_mysql_syntax
-- description: MySQL-compatible TRIM([{BOTH|LEADING|TRAILING}] [remstr] FROM str)

CREATE DATABASE IF NOT EXISTS test_trim_mysql_syntax_db;
USE test_trim_mysql_syntax_db;

-- whitespace forms (no remstr) route to trim/ltrim/rtrim
SELECT TRIM('  bar   ');
SELECT TRIM(BOTH FROM '  bar  ');
SELECT TRIM(LEADING FROM '  bar');
SELECT TRIM(TRAILING FROM 'bar  ');

-- single-char remstr (substring == char-set here)
SELECT TRIM(BOTH 'x' FROM 'xxxbarxxx');
SELECT TRIM(LEADING 'x' FROM 'xxxbarxxx');
SELECT TRIM(TRAILING 'x' FROM 'xxxbarxxx');
SELECT TRIM('x' FROM 'xxxbarxxx');

-- multi-char remstr: substring removed as a whole unit, repeatedly
SELECT TRIM(TRAILING 'xyz' FROM 'barxxyz');
SELECT TRIM(TRAILING 'xyz' FROM 'barxxyzxyz');
SELECT TRIM(LEADING 'ab' FROM 'ababfoo');
SELECT TRIM(BOTH 'ab' FROM 'abfooab');

-- empty remstr is a no-op
SELECT TRIM(BOTH '' FROM 'abc');

-- non-reserved keyword still usable as an identifier
SELECT leading FROM (SELECT 1 AS leading) t;
