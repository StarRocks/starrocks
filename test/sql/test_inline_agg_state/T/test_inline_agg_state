-- 1d. max(bigint) with bigint key  (state = int64_t, 8 bytes → qualifies)
select /*+SET_VAR(enable_inline_agg_state=false)*/ k_bigint, max(v_bigint) as m from t_num where k_bigint is not null group by k_bigint order by k_bigint limit 10;
