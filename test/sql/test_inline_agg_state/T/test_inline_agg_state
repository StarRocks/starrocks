-- 2d. min(int) with nullable key (NULL key group must get correct min)
select /*+SET_VAR(enable_inline_agg_state=false)*/ k_int, min(v_int) as m from t_num group by k_int order by k_int limit 5;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k_int, min(v_int) as m from t_num group by k_int order by k_int limit 5;

