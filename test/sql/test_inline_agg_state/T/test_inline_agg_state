-- =====================================================================
-- Section 8: Agg functions that do NOT qualify for inline state
-- (sum(bigint) → 16-byte state; avg → composite state; multiple functions)
-- =====================================================================

-- 8a. sum(bigint): state is int128_t (16 bytes) → inline NOT used
select /*+SET_VAR(enable_inline_agg_state=false)*/ k_int, sum(v_bigint) as s from t_num where k_int is not null group by k_int order by k_int limit 10;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k_int, sum(v_bigint) as s from t_num where k_int is not null group by k_int order by k_int limit 10;

-- 8b. avg: composite state → inline NOT used
select /*+SET_VAR(enable_inline_agg_state=false)*/ k_int, round(avg(v_int), 2) as a from t_num where k_int is not null group by k_int order by k_int limit 10;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k_int, round(avg(v_int), 2) as a from t_num where k_int is not null group by k_int order by k_int limit 10;

-- 8c. Multiple agg functions: always falls back (more than one function)
select /*+SET_VAR(enable_inline_agg_state=false)*/ k_int, count(*) as cnt, sum(v_int) as s from t_num where k_int is not null group by k_int order by k_int limit 10;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k_int, count(*) as cnt, sum(v_int) as s from t_num where k_int is not null group by k_int order by k_int limit 10;


-- =====================================================================
-- Section 9: Edge cases
-- =====================================================================

-- 9a. Empty table: no groups
select /*+SET_VAR(enable_inline_agg_state=false)*/ k, count(*) as cnt from t_empty group by k order by k;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k, count(*) as cnt from t_empty group by k order by k;

-- 9b. Single group (one distinct key value)
create table t_single (k int NOT NULL, v int NOT NULL)
    DUPLICATE KEY(k) DISTRIBUTED BY HASH(k) BUCKETS 1 PROPERTIES('replication_num' = '1');
insert into t_single values (1, 10), (1, 20), (1, 30);

select /*+SET_VAR(enable_inline_agg_state=false)*/ k, count(*) as cnt, sum(v) as s, min(v) as mi, max(v) as ma from t_single group by k;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k, count(*) as cnt, sum(v) as s, min(v) as mi, max(v) as ma from t_single group by k;

-- 9c. All keys are NULL (only one null-key group)
create table t_allnull (k int, v int NOT NULL)
    DUPLICATE KEY(k) DISTRIBUTED BY HASH(k) BUCKETS 1 PROPERTIES('replication_num' = '1');
insert into t_allnull (v) values (1), (2), (3);

select /*+SET_VAR(enable_inline_agg_state=false)*/ k, count(*) as cnt, sum(v) as s, min(v) as mi, max(v) as ma from t_allnull group by k;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k, count(*) as cnt, sum(v) as s, min(v) as mi, max(v) as ma from t_allnull group by k;

