-- 1e. min(bigint) with int key
select /*+SET_VAR(enable_inline_agg_state=false)*/ k_int, min(v_bigint) as m from t_num where k_int is not null group by k_int order by k_int limit 10;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k_int, min(v_bigint) as m from t_num where k_int is not null group by k_int order by k_int limit 10;

-- 1f. max(int) with int key
select /*+SET_VAR(enable_inline_agg_state=false)*/ k_int, max(v_int) as m from t_num where k_int is not null group by k_int order by k_int limit 10;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k_int, max(v_int) as m from t_num where k_int is not null group by k_int order by k_int limit 10;


