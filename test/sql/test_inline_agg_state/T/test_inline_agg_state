-- 1b. sum(int) with int key  (state = int64_t, 8 bytes → qualifies)
select /*+SET_VAR(enable_inline_agg_state=false)*/ k_int, sum(v_int) as s from t_num where k_int is not null group by k_int order by k_int limit 10;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k_int, sum(v_int) as s from t_num where k_int is not null group by k_int order by k_int limit 10;

-- 1c. min(int) with int key  (state = int32_t, 4 bytes → qualifies)
