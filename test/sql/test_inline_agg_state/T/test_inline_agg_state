-- 2f. min/max on NULL-only key group
select /*+SET_VAR(enable_inline_agg_state=false)*/ k_int, min(v_int) as mi, max(v_int) as ma from t_num where k_int is null group by k_int;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k_int, min(v_int) as mi, max(v_int) as ma from t_num where k_int is null group by k_int;


