-- name: test_inline_agg_state

create database db_${uuid0};
use db_${uuid0};

-- Setup: numeric key table (various int types, both nullable and not)
create table t_num (
    k_tinyint   tinyint,
    k_smallint  smallint,
    k_int       int,
    k_bigint    bigint,
    v_int       int     NOT NULL,
    v_bigint    bigint  NOT NULL
) DUPLICATE KEY(k_tinyint, k_smallint, k_int, k_bigint) DISTRIBUTED BY HASH(k_int) BUCKETS 3
PROPERTIES('replication_num' = '1');

-- 100000 rows: k_int in [0,999], v_int in [1,100000]
insert into t_num
    SELECT generate_series % 127, generate_series % 1000, generate_series % 1000,
           generate_series % 1000, generate_series, generate_series
    FROM TABLE(generate_series(1, 100000));
-- 1000 rows with NULL k_int (exercises null-key inline path)
insert into t_num (k_smallint, k_int, k_bigint, v_int, v_bigint)
    SELECT NULL, NULL, generate_series % 100, generate_series, generate_series
    FROM TABLE(generate_series(1, 1000));

-- Setup: string key table (nullable key)
create table t_str (
    k_str   varchar(64),
    v_int   int NOT NULL
) DUPLICATE KEY(k_str) DISTRIBUTED BY HASH(k_str) BUCKETS 3
PROPERTIES('replication_num' = '1');

insert into t_str SELECT generate_series % 1000, generate_series FROM TABLE(generate_series(1, 100000));
-- 1000 rows with NULL k_str
insert into t_str (v_int) SELECT generate_series FROM TABLE(generate_series(1, 1000));

-- Setup: multi-column key table (serialized / compressed key hash maps)
create table t_multi (
    k0  int         NOT NULL,
    k1  int         NOT NULL,
    k2  varchar(32) NOT NULL,
    v   int         NOT NULL
) DUPLICATE KEY(k0) DISTRIBUTED BY HASH(k0) BUCKETS 3
PROPERTIES('replication_num' = '1');

insert into t_multi
    SELECT generate_series % 100, generate_series % 50, generate_series % 200, generate_series
    FROM TABLE(generate_series(1, 100000));

-- Setup: empty table (edge case)
create table t_empty (k int, v int NOT NULL) DUPLICATE KEY(k) DISTRIBUTED BY HASH(k) BUCKETS 3
PROPERTIES('replication_num' = '1');


-- =====================================================================
-- Section 1: Non-nullable int key  (AggHashMapWithOneNumberKey<TYPE_INT>)
