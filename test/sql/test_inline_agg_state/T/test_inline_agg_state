select /*+SET_VAR(enable_inline_agg_state=false)*/ k_tinyint, count(*) as cnt, sum(v_int) as s from t_num where k_tinyint is not null group by k_tinyint order by k_tinyint;
select /*+SET_VAR(enable_inline_agg_state=true)*/  k_tinyint, count(*) as cnt, sum(v_int) as s from t_num where k_tinyint is not null group by k_tinyint order by k_tinyint;


