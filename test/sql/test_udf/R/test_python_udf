CREATE FUNCTION nested_arr_arr(array<array<int>>) RETURNS string
properties(
    "symbol" = "echo",
    "type" = "Python",
    "file" = "inline",
    "input" = "scalar"
)
AS
$$
def echo(x):
    # x must be a list of lists of ints, sum total
    return str(sum(sum(inner) for inner in x))
$$;
-- result:
-- !result
select nested_arr_arr([[1,2,3],[4,5]]);
-- result:
15
-- !result
CREATE FUNCTION nested_arr_map(array<map<string,int>>) RETURNS string
properties(
    "symbol" = "echo",
    "type" = "Python",
    "file" = "inline",
    "input" = "scalar"
)
AS
$$
def echo(x):
    # x must be a list of dicts (not list of tuples)
    return ",".join(sorted(str(type(e).__name__) for e in x))
$$;
-- result:
-- !result
select nested_arr_map([map('a', 1), map('b', 2)]);
-- result:
dict,dict
-- !result
CREATE FUNCTION nested_map_arr(map<string,array<int>>) RETURNS int
properties(
    "symbol" = "echo",
    "type" = "Python",
    "file" = "inline",
    "input" = "scalar"
)
AS
$$
def echo(x):
    # x must be a dict whose values are lists
    return sum(sum(v) for v in x.values())
$$;
-- result:
-- !result
select nested_map_arr(map('k1', [1,2,3], 'k2', [4,5]));
-- result:
15
-- !result
CREATE FUNCTION nested_struct(struct<a array<int>, b map<string,int>>) RETURNS string
properties(
    "symbol" = "echo",
    "type" = "Python",
    "file" = "inline",
    "input" = "scalar"
)
AS
$$
def echo(x):
    # x must be a dict with keys 'a' (list) and 'b' (dict)
    return "a={};b={}".format(sum(x['a']), sorted(x['b'].items()))
$$;
-- result:
-- !result
select nested_struct(named_struct('a', [10,20,30], 'b', map('x', 1, 'y', 2)));
-- result:
a=60;b=[('x', 1), ('y', 2)]
-- !result
