-- name: test_range_partition_prune_null_date @native
-- This test verifies that NULL values in RANGE partitions with MINVALUE lower bound
-- are NOT incorrectly pruned by BE-side dynamic partition pruning.
-- NULL values go to the partition whose lower bound is MINVALUE.
create database test_dyn_prune_${uuid0};
use test_dyn_prune_${uuid0};

CREATE TABLE t_range_null_date (
    dt DATE,
    v INT
) ENGINE=OLAP
DUPLICATE KEY(dt)
PARTITION BY RANGE(dt) (
    PARTITION p1 VALUES LESS THAN ("2024-01-01"),
    PARTITION p2 VALUES LESS THAN ("2024-02-01"),
    PARTITION p3 VALUES LESS THAN ("2024-03-01")
)
DISTRIBUTED BY HASH(dt) BUCKETS 1
PROPERTIES ("replication_num" = "1");

INSERT INTO t_range_null_date VALUES
    (NULL, 1), (NULL, 2),
    ('2024-01-15', 3),
    ('2024-02-15', 4);

-- IS NULL must return the 2 NULL rows from p0 (NOT be pruned away)
SELECT v FROM t_range_null_date WHERE dt IS NULL ORDER BY v;

-- IS NOT NULL should return the non-null rows
SELECT v FROM t_range_null_date WHERE dt IS NOT NULL ORDER BY v;

-- equality on a date in p1
SELECT v FROM t_range_null_date WHERE dt = '2024-01-15';

-- NULL-safe comparison
SELECT v FROM t_range_null_date WHERE dt <=> NULL ORDER BY v;

-- combined: NULL or a specific date
SELECT COUNT(*) FROM t_range_null_date WHERE dt IS NULL OR dt = '2024-02-15';

-- verify total row count
SELECT COUNT(*) FROM t_range_null_date;

drop table t_range_null_date force;
drop database test_dyn_prune_${uuid0} force;


-- name: test_range_partition_prune_null_tinyint @native
-- TINYINT with MINVALUE has a small range (228 values), fits under default limit 4096.
-- This is the most likely scenario to trigger the NULL pruning bug.
create database test_dyn_prune_${uuid0};
use test_dyn_prune_${uuid0};

CREATE TABLE t_range_null_tinyint (
    k TINYINT,
    v INT
) ENGINE=OLAP
DUPLICATE KEY(k)
PARTITION BY RANGE(k) (
    PARTITION p1 VALUES [("-128"), ("0")),
    PARTITION p2 VALUES [("0"), ("5")),
    PARTITION p3 VALUES [("5"), ("127"))
)
DISTRIBUTED BY HASH(k) BUCKETS 1
PROPERTIES ("replication_num" = "1");

INSERT INTO t_range_null_tinyint VALUES
    (NULL, 1), (NULL, 2),
    (-10, 3), (-1, 4),
    (0, 5), (25, 6),
    (50, 7), (100, 8);

-- IS NULL must not prune p0
SELECT v FROM t_range_null_tinyint WHERE k IS NULL ORDER BY v;

-- negative values in p0
SELECT v FROM t_range_null_tinyint WHERE k = -10;

-- IS NOT NULL
SELECT COUNT(*) FROM t_range_null_tinyint WHERE k IS NOT NULL;

-- verify total
SELECT COUNT(*) FROM t_range_null_tinyint;

-- equality on p1
SELECT v FROM t_range_null_tinyint WHERE k = 25;

drop table t_range_null_tinyint force;
drop database test_dyn_prune_${uuid0} force;


