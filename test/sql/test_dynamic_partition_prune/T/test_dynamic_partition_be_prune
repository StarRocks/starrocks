-- name: test_dynamic_partition_prune_limit_session_var
-- Verify the dynamic_partition_prune_limit session variable.
create database test_dyn_prune_${uuid0};
use test_dyn_prune_${uuid0};

CREATE TABLE t_limit_test (
    k INT NOT NULL,
    v INT
) ENGINE=OLAP
DUPLICATE KEY(k)
PARTITION BY RANGE(k) (
    PARTITION p1 VALUES [('0'), ('100')),
    PARTITION p2 VALUES [('100'), ('200')),
    PARTITION p3 VALUES [('200'), ('300'))
)
DISTRIBUTED BY HASH(k) BUCKETS 1
PROPERTIES ("replication_num" = "1");

INSERT INTO t_limit_test VALUES (50, 1), (150, 2), (250, 3);

-- default limit (4096): pruning should work, 100 values per partition < 4096
SELECT v FROM t_limit_test WHERE k = 50;
SELECT v FROM t_limit_test WHERE k = 150;

-- set limit very small: pruning disabled because range > limit
set dynamic_partition_prune_limit = 10;
SELECT v FROM t_limit_test WHERE k = 50;
SELECT v FROM t_limit_test WHERE k = 150;

-- set limit very large
set dynamic_partition_prune_limit = 100000;
SELECT v FROM t_limit_test WHERE k = 50;
SELECT v FROM t_limit_test WHERE k = 150;

-- reset
set dynamic_partition_prune_limit = 4096;

drop table t_limit_test force;
drop database test_dyn_prune_${uuid0} force;


