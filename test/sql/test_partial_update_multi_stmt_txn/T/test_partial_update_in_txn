-- name: test_partial_update_after_full_insert_same_table_rejected
-- A partial-update INSERT targeting a table already modified earlier in the same explicit
-- transaction is rejected (ERR_EXPLICIT_TXN_PARTIAL_UPDATE_ON_MODIFIED_TABLE, 5308), because the
-- batch publish path cannot correctly merge a partial update against uncommitted same-transaction
-- writes. The transaction is then rolled back, so the table keeps its pre-transaction data.
create database db_${uuid0};
use db_${uuid0};
CREATE TABLE t1 (k INT NOT NULL, v1 INT NULL, v2 INT NULL) PRIMARY KEY(k) DISTRIBUTED BY HASH(k) BUCKETS 1 PROPERTIES ("replication_num" = "1");
insert into t1 values (1, 100, 1000), (2, 200, 2000);
set enable_sql_transaction = true;
begin;
insert into t1 values (3, 300, 3000);
insert into t1 (k, v2) values (3, 3333);
rollback;
select * from t1 order by k;
drop database db_${uuid0};


