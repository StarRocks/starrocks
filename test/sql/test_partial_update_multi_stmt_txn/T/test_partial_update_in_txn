-- name: test_single_partial_update_in_txn_ok
-- A single partial update in a transaction (the only statement touching the table) is fine:
-- it is one op_write at publish, no multi-op batch merge.
create database db_${uuid0};
use db_${uuid0};
CREATE TABLE t1 (k INT NOT NULL, v1 INT NULL, v2 INT NULL) PRIMARY KEY(k) DISTRIBUTED BY HASH(k) BUCKETS 1 PROPERTIES ("replication_num" = "1");
insert into t1 values (1, 100, 1000), (2, 200, 2000);
set enable_sql_transaction = true;
begin;
insert into t1 (k, v1) values (1, 111);
commit;
select * from t1 order by k;
drop database db_${uuid0};


-- name: test_partial_update_different_tables_ok
-- Partial updates targeting DIFFERENT tables in one transaction are fine (each is the only
-- modification of its own table).
create database db_${uuid0};
use db_${uuid0};
CREATE TABLE t1 (k INT NOT NULL, v1 INT NULL, v2 INT NULL) PRIMARY KEY(k) DISTRIBUTED BY HASH(k) BUCKETS 1 PROPERTIES ("replication_num" = "1");
CREATE TABLE t2 (k INT NOT NULL, v1 INT NULL, v2 INT NULL) PRIMARY KEY(k) DISTRIBUTED BY HASH(k) BUCKETS 1 PROPERTIES ("replication_num" = "1");
insert into t1 values (1, 100, 1000);
insert into t2 values (1, 100, 1000);
set enable_sql_transaction = true;
begin;
insert into t1 (k, v1) values (1, 111);
insert into t2 (k, v2) values (1, 2222);
commit;
select 't1' tbl, k, v1, v2 from t1 order by k;
select 't2' tbl, k, v1, v2 from t2 order by k;
drop database db_${uuid0};


-- name: test_full_inserts_same_table_in_txn_ok
-- Multiple FULL inserts (no partial column list) on the same table in one transaction are fine
-- (this is the supported multi-statement transaction case).
create database db_${uuid0};
use db_${uuid0};
CREATE TABLE t1 (k INT NOT NULL, v1 INT NULL, v2 INT NULL) PRIMARY KEY(k) DISTRIBUTED BY HASH(k) BUCKETS 1 PROPERTIES ("replication_num" = "1");
insert into t1 values (1, 100, 1000);
set enable_sql_transaction = true;
begin;
insert into t1 values (2, 200, 2000);
insert into t1 values (3, 300, 3000);
commit;
select * from t1 order by k;
drop database db_${uuid0};
