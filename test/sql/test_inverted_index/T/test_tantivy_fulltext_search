-- name: test_tantivy_add_drop_index @cloud
CREATE DATABASE IF NOT EXISTS ${uuid0};
USE ${uuid0};

-- ADD INDEX on empty table, then insert
CREATE TABLE t_tantivy_add_idx (
    id INT,
    content VARCHAR(65535)
) DUPLICATE KEY(id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1", "replicated_storage" = "false");

ALTER TABLE t_tantivy_add_idx ADD INDEX gin_content (content) USING GIN ("parser" = "english", "imp_lib" = "tantivy");
function: wait_alter_table_finish()
INSERT INTO t_tantivy_add_idx VALUES (1, 'the quick brown fox'), (2, 'lazy dog sleeps'), (3, NULL), (4, 'fox jumps high');
SELECT count(*) FROM t_tantivy_add_idx WHERE content MATCH_ANY 'fox';
SELECT count(*) FROM t_tantivy_add_idx WHERE content IS NULL;

-- ADD INDEX with backfill (data exists before index)
CREATE TABLE t_tantivy_backfill (
    id INT,
    content VARCHAR(65535)
) DUPLICATE KEY(id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1", "replicated_storage" = "false");

INSERT INTO t_tantivy_backfill VALUES (1, 'search engine design'), (2, 'tantivy full text'), (3, 'quick brown fox'), (4, NULL);
ALTER TABLE t_tantivy_backfill ADD INDEX gin_content (content) USING GIN ("parser" = "english", "imp_lib" = "tantivy");
function: wait_alter_table_finish()
SELECT count(*) FROM t_tantivy_backfill WHERE content MATCH_ANY 'fox';
SELECT count(*) FROM t_tantivy_backfill WHERE content MATCH_ALL 'full text';

-- DROP INDEX single column
DROP INDEX gin_content ON t_tantivy_backfill;
function: wait_alter_table_finish()
SELECT count(*) FROM t_tantivy_backfill WHERE content MATCH_ANY 'fox';

-- DROP INDEX multi-column: drop one, keep the other
CREATE TABLE t_tantivy_multi_drop (
    id INT,
    title VARCHAR(65535),
    body VARCHAR(65535),
    INDEX gin_title (title) USING GIN ("parser" = "english", "imp_lib" = "tantivy"),
    INDEX gin_body (body) USING GIN ("parser" = "english", "imp_lib" = "tantivy")
) DUPLICATE KEY(id)
DISTRIBUTED BY HASH(id) BUCKETS 1
PROPERTIES ("replication_num" = "1", "replicated_storage" = "false");

INSERT INTO t_tantivy_multi_drop VALUES (1, 'starrocks analytics', 'the quick fox'), (2, 'tantivy search', 'lazy dog');
SELECT count(*) FROM t_tantivy_multi_drop WHERE title MATCH_ANY 'search';
SELECT count(*) FROM t_tantivy_multi_drop WHERE body MATCH_ANY 'fox';
DROP INDEX gin_title ON t_tantivy_multi_drop;
function: wait_alter_table_finish()
SELECT count(*) FROM t_tantivy_multi_drop WHERE body MATCH_ANY 'fox';

-- Compaction after DROP INDEX
INSERT INTO t_tantivy_multi_drop VALUES (3, 'new row', 'compaction fox test');
ALTER TABLE t_tantivy_multi_drop COMPACT;
function: wait_alter_table_finish()
SELECT count(*) FROM t_tantivy_multi_drop WHERE body MATCH_ANY 'fox';

DROP TABLE t_tantivy_add_idx;
DROP TABLE t_tantivy_backfill;
DROP TABLE t_tantivy_multi_drop;
DROP DATABASE ${uuid0};

