-- Heavy-load smoke test: 15 separate INSERTs into a single tablet, each
-- creating a new rowset. Autonomous compaction must merge them without
-- data loss. Exercises the merge_results_to_txn_log path with multiple
-- subtasks combined per tablet.
create database test_lake_auto_compaction_many_${uuid0};
use test_lake_auto_compaction_many_${uuid0};

ADMIN SET FRONTEND CONFIG ("enable_lake_autonomous_compaction" = "true");
ADMIN SET FRONTEND CONFIG ("lake_compaction_version_delta_threshold" = "2");
ADMIN SET FRONTEND CONFIG ("lake_compaction_max_interval_ms" = "1000");
ADMIN SET FRONTEND CONFIG ("enable_file_bundling" = "false");
UPDATE information_schema.be_configs SET VALUE = 'true' WHERE name = 'enable_lake_autonomous_compaction';
UPDATE information_schema.be_configs SET VALUE = '1.0' WHERE name = 'lake_autonomous_compaction_score_threshold';

CREATE TABLE auto_many (
    k1 BIGINT NOT NULL,
    v1 VARCHAR(100)
)
DUPLICATE KEY(k1)
DISTRIBUTED BY HASH(k1) BUCKETS 1;

INSERT INTO auto_many VALUES (1, 'r1');
INSERT INTO auto_many VALUES (2, 'r2');
INSERT INTO auto_many VALUES (3, 'r3');
INSERT INTO auto_many VALUES (4, 'r4');
INSERT INTO auto_many VALUES (5, 'r5');
INSERT INTO auto_many VALUES (6, 'r6');
INSERT INTO auto_many VALUES (7, 'r7');
INSERT INTO auto_many VALUES (8, 'r8');
INSERT INTO auto_many VALUES (9, 'r9');
INSERT INTO auto_many VALUES (10, 'r10');
INSERT INTO auto_many VALUES (11, 'r11');
INSERT INTO auto_many VALUES (12, 'r12');
INSERT INTO auto_many VALUES (13, 'r13');
INSERT INTO auto_many VALUES (14, 'r14');
INSERT INTO auto_many VALUES (15, 'r15');

SELECT sleep(25);

SELECT COUNT(*) FROM auto_many;
SELECT * FROM auto_many ORDER BY k1;

ADMIN SET FRONTEND CONFIG ("enable_lake_autonomous_compaction" = "false");
ADMIN SET FRONTEND CONFIG ("lake_compaction_version_delta_threshold" = "10");
ADMIN SET FRONTEND CONFIG ("lake_compaction_max_interval_ms" = "1800000");
ADMIN SET FRONTEND CONFIG ("enable_file_bundling" = "true");
UPDATE information_schema.be_configs SET VALUE = 'false' WHERE name = 'enable_lake_autonomous_compaction';
UPDATE information_schema.be_configs SET VALUE = '10.0' WHERE name = 'lake_autonomous_compaction_score_threshold';

DROP DATABASE test_lake_auto_compaction_many_${uuid0} FORCE;
