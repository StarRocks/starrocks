CREATE TABLE auto_pk (
    k1 BIGINT NOT NULL,
    v1 VARCHAR(100),
    v2 BIGINT
)
PRIMARY KEY(k1)
DISTRIBUTED BY HASH(k1) BUCKETS 1;

INSERT INTO auto_pk VALUES (1, 'a', 100), (2, 'b', 200), (3, 'c', 300);
INSERT INTO auto_pk VALUES (4, 'd', 400), (5, 'e', 500);
