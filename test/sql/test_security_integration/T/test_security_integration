-- name: test_security_integration
create security integration oidc properties("type"="authentication_jwt", "jwks_url"="jwks.json", "principal_field"="sub");
show create security integration oidc;
alter security integration oidc set ("principal_field"="preferred_name");
show create security integration oidc;
drop security integration oidc;

-- name: test_ldap_security_integration_with_bind_dn_pattern
create security integration ldap_pattern properties("type"="authentication_ldap_simple", "authentication_ldap_simple_server_host"="localhost", "authentication_ldap_simple_server_port"="389", "authentication_ldap_simple_bind_dn_pattern"="uid=${USER},ou=People,dc=example,dc=com");
