#!/bin/sh
set -e

case "$1" in
    configure)
        # 1. Create starrocks group
        if ! getent group starrocks >/dev/null; then
            if ! groupadd --system starrocks; then
                echo "Error: Failed to create system group 'starrocks'." >&2
                exit 1
            fi
        fi

        # 2. Create starrocks user
        if ! getent passwd starrocks >/dev/null; then
            if ! useradd --system \
                --gid starrocks \
                --home-dir /var/lib/starrocks \
                --no-create-home \
                --shell /usr/sbin/nologin \
                --comment "StarRocks system user" \
                starrocks; then
                echo "Error: Failed to create system user 'starrocks'." >&2
                exit 1
            fi
        fi

        # 3. Create specific subdirectories for FE,BE,CN with correct ownership and permissions
        echo "Creating StarRocks runtime directories..."

        # Always ensure shared base directories exist
        for dir in /var/log/starrocks /var/lib/starrocks; do
            install -d -o starrocks -g starrocks -m 0750 "$dir"
        done

        # Map package name to specific directories
        case "$DPKG_MAINTSCRIPT_PACKAGE" in
            starrocks-fe)
                COMPONENT_DIRS="/var/log/starrocks/fe /var/lib/starrocks/fe /var/lib/starrocks/fe/meta"
                ;;
            starrocks-be)
                COMPONENT_DIRS="/var/log/starrocks/be /var/lib/starrocks/be /var/lib/starrocks/be/storage"
                ;;
            starrocks-cn)
                COMPONENT_DIRS="/var/log/starrocks/cn /var/lib/starrocks/cn /var/lib/starrocks/cn/cache"
                ;;
        esac

        for dir in $COMPONENT_DIRS; do
            install -d -o starrocks -g starrocks -m 0750 "$dir"
        done

        # Secure the configuration directory
        CONF_DIR="/etc/starrocks/$COMP"
        if [ -d "$CONF_DIR" ]; then
            chown -R root:starrocks "$CONF_DIR"
            find "$CONF_DIR" -type d -exec chmod 750 {} \;
            find "$CONF_DIR" -type f -exec chmod 640 {} \;
        fi

        # Reload systemd units to pick up changes immediately
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload >/dev/null 2>&1 || true
        fi
    ;;

    abort-upgrade|abort-remove|abort-deconfigure)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

exit 0