#!/bin/sh
set -e

case "$1" in
    configure)
        # 1. Create starrocks group
        if ! getent group starrocks >/dev/null; then
            if command -v groupadd >/dev/null 2>&1; then
                groupadd --system starrocks
            elif command -v addgroup >/dev/null 2>&1; then
                addgroup --system starrocks
            else
                echo "Error: Neither 'groupadd' nor 'addgroup' found." >&2
                exit 1
            fi
        fi

        # 2. Create base directories
        for dir in /var/log/starrocks /var/lib/starrocks; do
            if [ ! -d "$dir" ]; then
                mkdir -p "$dir"
            fi
        done

        # 3. Create starrocks user
        if ! getent passwd starrocks >/dev/null; then
            if command -v useradd >/dev/null 2>&1; then
                useradd --system \
                    --gid starrocks \
                    --home-dir /var/lib/starrocks \
                    --no-create-home \
                    --shell /usr/sbin/nologin \
                    --comment "StarRocks system user" \
                    starrocks
            elif command -v adduser >/dev/null 2>&1; then
                # Note: adduser uses --ingroup and --gecos instead of --gid and --comment
                adduser --system \
                    --ingroup starrocks \
                    --home /var/lib/starrocks \
                    --no-create-home \
                    --shell /usr/sbin/nologin \
                    --gecos "StarRocks system user" \
                    starrocks
            else
                echo "Error: Neither 'useradd' nor 'adduser' found." >&2
                exit 1
            fi
        fi
        
        # 4. Enforce ownership and permissions on base and specific directories
        echo "Ensuring StarRocks runtime directories exist..."
        for dir in /var/log/starrocks /var/lib/starrocks; do
            install -d -o starrocks -g starrocks -m 0750 "$dir"
        done

        # Map package name to specific directories and derive component name
        #
        # IMPORTANT:
        # - The component-specific data/cache/storage directories below (under /var/lib/starrocks)
        #   MUST match the paths configured in the StarRocks configuration files that are
        #   patched by the packaging/build logic (e.g. build.sh).
        # - If either the configuration paths or these directories are changed, the other
        #   must be updated accordingly, otherwise StarRocks services may fail to start
        #   because they will look for metadata or storage in a different location than
        #   the one created here.
        # - When modifying FE/BE/CN data directories, keep this case statement and the
        #   corresponding configuration patching in strict sync.
        COMPONENT_DIRS=""
        COMP=""
        case "$DPKG_MAINTSCRIPT_PACKAGE" in
            starrocks-fe)
                COMP="fe"
                # FE directories: log, runtime data root, and metadata directory.
                # Keep /var/lib/starrocks/fe and /var/lib/starrocks/fe/meta in sync with FE configs.
                COMPONENT_DIRS="/var/log/starrocks/fe /var/lib/starrocks/fe /var/lib/starrocks/fe/meta"
                ;;
            starrocks-be)
                COMP="be"
                # BE directories: log, runtime data root, and storage directory.
                # Keep /var/lib/starrocks/be and /var/lib/starrocks/be/storage in sync with BE configs.
                COMPONENT_DIRS="/var/log/starrocks/be /var/lib/starrocks/be /var/lib/starrocks/be/storage"
                ;;
            starrocks-cn)
                COMP="cn"
                # CN directories: log, runtime data root, and cache directory.
                # Keep /var/lib/starrocks/cn and /var/lib/starrocks/cn/cache in sync with CN configs.
                COMPONENT_DIRS="/var/log/starrocks/cn /var/lib/starrocks/cn /var/lib/starrocks/cn/cache"
                ;;
            *)
                # Unknown or unsupported package; do not touch component-specific paths
                COMP=""
                COMPONENT_DIRS=""
                ;;
        esac

        for dir in $COMPONENT_DIRS; do
            install -d -o starrocks -g starrocks -m 0750 "$dir"
        done

        # Secure the configuration directory for the detected component  
        #  
        # NOTE:  
        # - For Debian packages we intentionally keep configuration under /etc/starrocks/$COMP  
        #   owned by root and only readable by the 'starrocks' group (root:starrocks with  
        #   750 for directories and 640 for files).  
        # - This is stricter than the default tarball installation, where the StarRocks  
        #   process may write its own configuration files.  
        # - With this Debian packaging, configuration is expected to be managed by an  
        #   administrator (root) rather than by the running service.  
        # - If a deployment requires auto-generated or runtime-writable configuration,  
        #   use a separate writable location (e.g. under /var/lib/starrocks) or adjust  
        #   permissions for the specific files as part of local administration.  
        if [ -n "$COMP" ]; then  
            CONF_DIR="/etc/starrocks/$COMP"  
            if [ -d "$CONF_DIR" ]; then  
                chown -R root:starrocks "$CONF_DIR"  
                find "$CONF_DIR" -type d -exec chmod 750 {} \;  
                find "$CONF_DIR" -type f -exec chmod 640 {} \;  
            fi  
        fi

        # Reload systemd units to pick up changes immediately
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload >/dev/null 2>&1 || true

            # If this is an upgrade, try to restart the service to apply changes
            if [ -n "$COMP" ] && systemctl is-active --quiet "starrocks-$COMP" 2>/dev/null; then
                echo "Restarting StarRocks $COMP to apply upgrade..."
                systemctl try-restart "starrocks-$COMP" || true
            fi
        fi
    ;;

    abort-upgrade|abort-remove|abort-deconfigure)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

exit 0