#!/bin/sh
set -e

case "$1" in
    configure)
        # 1. Create starrocks group
        if ! getent group starrocks >/dev/null; then
            groupadd --system starrocks
        fi

        # 2. Create starrocks user
        if ! getent passwd starrocks >/dev/null; then
            useradd --system \
                --gid starrocks \
                --home-dir /var/lib/starrocks \
                --no-create-home \
                --shell /usr/sbin/nologin \
                --comment "StarRocks system user" \
                starrocks
        fi

        # 3. Create specific subdirectories for FE,BE,CN with correct ownership and permissions
        echo "Creating StarRocks runtime directories..."
        for dir in \
            /var/log/starrocks \
            /var/log/starrocks/fe \
            /var/log/starrocks/be \
            /var/log/starrocks/cn \
            /var/lib/starrocks \
            /var/lib/starrocks/fe \
            /var/lib/starrocks/fe/meta \
            /var/lib/starrocks/be \
            /var/lib/starrocks/be/storage \
            /var/lib/starrocks/cn \
            /var/lib/starrocks/cn/cache
        do
            install -d -o starrocks -g starrocks -m 0750 "$dir"
        done
        
        # Secure the configuration directory
        if [ -d /etc/starrocks ]; then
            chown -R root:starrocks /etc/starrocks
            find /etc/starrocks -type d -exec chmod 750 {} \;  
            find /etc/starrocks -type f -exec chmod 640 {} \;  
        fi
    ;;

    abort-upgrade|abort-remove|abort-deconfigure)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

exit 0