#!/bin/sh
set -e

case "$1" in
    configure)
        # 1. Create starrocks group
        if ! getent group starrocks >/dev/null; then
            groupadd --system starrocks
        fi

        # 2. Create starrocks user
        if ! getent passwd starrocks >/dev/null; then
            useradd --system \
                --gid starrocks \
                --home-dir /var/lib/starrocks \
                --no-create-home \
                --shell /usr/sbin/nologin \
                --comment "StarRocks system user" \
                starrocks
        fi

        # 3. Create specific subdirectories for FE and BE
        echo "Creating StarRocks runtime directories..."
        mkdir -p /var/log/starrocks/fe /var/log/starrocks/be
        mkdir -p /var/lib/starrocks/fe/meta /var/lib/starrocks/be/storage

        # 4. Set ownership and permissions
        echo "Setting permissions for starrocks user..."
        chown -R starrocks:starrocks /var/log/starrocks
        chown -R starrocks:starrocks /var/lib/starrocks
        
        # Secure the configuration directory
        if [ -d /etc/starrocks ]; then
            chown -R root:starrocks /etc/starrocks
            find /etc/starrocks -type d -exec chmod 750 {} \;  
            find /etc/starrocks -type f -exec chmod 640 {} \;  
        fi
    ;;

    abort-upgrade|abort-remove|abort-deconfigure)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

exit 0