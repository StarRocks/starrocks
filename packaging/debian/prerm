#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        if [ -n "$DPKG_MAINTSCRIPT_PACKAGE" ]; then
            case "$DPKG_MAINTSCRIPT_PACKAGE" in
                starrocks-*)
                    COMP=${DPKG_MAINTSCRIPT_PACKAGE#starrocks-}
                    ;;
                *)
                    COMP=""
                    ;;
            esac

            if [ -n "$COMP" ] && [ -d /run/systemd/system ] && command -v systemctl >/dev/null 2>&1 && systemctl is-active --quiet "starrocks-$COMP" 2>/dev/null; then
                echo "Stopping StarRocks $COMP service..."
                systemctl stop "starrocks-$COMP" || true
            fi
        fi
    ;;

    failed-upgrade)
    ;;

    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

exit 0