+        int ret = 0;
+        unsigned arena_ind;
+        NEITHER_READ_NOR_WRITE();
+        MIB_UNSIGNED(arena_ind, 1);
+        arena_i_dontdump(tsd_tsdn(tsd), arena_ind);
+label_return:
+        return ret;
+}
